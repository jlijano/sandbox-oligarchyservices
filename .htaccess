AddDefaultCharset UTF-8
DirectoryIndex index.html
Options -Indexes

ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Keep production traffic on HTTPS when SSL is enabled for the domain.
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Keep the public login URL stable while serving the PHP login form.
  RewriteRule ^login\.html$ /login.php [L]

  # Serve the Carrier and Switchboard portal modules from their requested app routes.
  RewriteRule ^carrier/?$ /carrier.php [L]
  RewriteRule ^switchboard/?$ /switchboard.php [L]

  # Protect server-side helpers and generated credentials from browser access.
  RewriteRule ^includes/ - [F,L]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), geolocation=(), microphone=()"
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 0 seconds"
  ExpiresByType text/javascript "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
</IfModule>
